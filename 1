<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="utf-8"/>
<title>Adulto Anciano - Apunte de Enfermería</title>
<style>
  @page {
    size: A5;
    margin: 16mm 13mm 18mm 13mm;
  }

  :root{
    --ink:#2a3a3f;
    --ink-soft:#4e6468;
    --title:#146c63;
    --title-2:#2b6cb0;
    --line:#bfd4d9;
    --line-strong:#8fb7c0;
    --paper:#ffffff;
    --paper-soft:#f9fcfc;
    --mint-050:#effbf6;
    --mint-100:#dcf6eb;
    --mint-200:#c9eddc;
    --mint-300:#aee0ca;
    --blue-050:#eef6ff;
    --blue-100:#dcecff;
    --blue-200:#c6e0fb;
    --blue-300:#9ccaf1;
    --sage:#45a384;
    --teal:#178d82;
    --accent:#5da8d8;
    --gray-050:#fbfcfd;
    --gray-100:#f3f6f7;
    --gray-200:#dfe8eb;
    --gray-300:#cddade;
    --shadow:none;
  }

  *{
    box-sizing:border-box;
  }

  html{
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  body {
    font-family: "Arial", "Helvetica", sans-serif;
    font-size: 10.3pt;
    line-height: 1.58;
    color: var(--ink);
    background: var(--paper);
    margin: 0;
    counter-reset: page;
  }

  h1, h2, h3, h4 {
    margin: 0;
    page-break-after: avoid;
    break-after: avoid;
    font-family: "Arial", "Helvetica", sans-serif;
  }

  h1 {
    font-size: 22pt;
    line-height: 1.2;
    text-align: center;
    color: var(--title);
    letter-spacing: .4px;
    text-transform: uppercase;
  }

  h2 {
    font-size: 15.2pt;
    line-height: 1.3;
    color: var(--title);
    margin: 0 0 .9em 0;
    padding: 0 0 .45em 0;
    border-bottom: 2px solid var(--mint-300);
    text-transform: uppercase;
    letter-spacing: .2px;
  }

  h3 {
    font-size: 12.1pt;
    line-height: 1.35;
    color: var(--title-2);
    margin: 1.15em 0 .5em 0;
    padding: .18em 0 .18em .55em;
    border-left: 4px solid var(--blue-300);
    background: linear-gradient(to right, rgba(220,236,255,.95), rgba(220,246,235,.55) 62%, transparent 92%);
    border-radius: 2px;
  }

  h4 {
    font-size: 10.7pt;
    line-height: 1.35;
    color: var(--title);
    margin: 1em 0 .4em 0;
    padding-bottom: .16em;
    border-bottom: 1px solid var(--gray-200);
    font-weight: 700;
  }

  p {
    margin: .58em 0;
    text-align: justify;
    widows: 2;
    orphans: 2;
  }

  ul, ol {
    margin: .55em 0 .75em 1.2em;
    padding-left: .25em;
  }

  li {
    margin: .26em 0;
    text-align: left;
  }

  strong { color: #244f58; }
  em { color: #5d7074; }

  section {
    position: relative;
  }

  .page-break {
    page-break-before: always;
    break-before: page;
  }

  .cover {
    min-height: calc(100vh - 20mm);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 18mm 8mm 14mm;
    border: 1.5px solid var(--mint-300);
    background:
      linear-gradient(180deg, #f2fbf7 0%, #e6f8f0 35%, #e8f3ff 72%, #f8fdff 100%);
    position: relative;
  }

  .cover::before,
  .cover::after{
    content:"";
    position:absolute;
    inset:10mm;
    border:1px solid rgba(111,174,184,.28);
    pointer-events:none;
  }

  .cover h1 {
    margin-bottom: .45em;
  }

  .cover h2 {
    border: none;
    padding: 0;
    margin: 0 0 1.4em 0;
    color: var(--ink-soft);
    font-size: 11.6pt;
    font-weight: 600;
    text-transform: none;
    letter-spacing: .3px;
  }

  .cover .image-placeholder{
    max-width: 78%;
    margin-top: 1.2em;
  }

  .index {
    margin-top: .4em;
    padding: 0;
  }

  .index h2 {
    text-align: center;
    border-bottom: 0;
    margin-bottom: .9em;
    background: linear-gradient(to right, rgba(93,168,216,.08), var(--mint-100), rgba(69,163,132,.08));
    padding: .3em 0;
  }

  .index ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid var(--line);
    background: linear-gradient(180deg, #ffffff 0%, #fbfdfd 100%);
  }

  .index li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: .7em;
    align-items: center;
    margin: 0;
    padding: .55em .8em;
    border-bottom: 1px solid var(--gray-200);
  }

  .index li:nth-child(odd){
    background: var(--gray-050);
  }

  .index li span:first-child{
    color: var(--ink);
    font-weight: 600;
  }

  .index li span:last-child{
    min-width: 1.9em;
    text-align: center;
    color: var(--title);
    font-weight: 700;
    background: linear-gradient(180deg, #dff7ec 0%, #d7f0f5 100%);
    border: 1px solid var(--mint-300);
    padding: .1em .45em;
    border-radius: 999px;
  }

  .unidad {
    padding: 0;
  }

  .unidad > h2{
    background: linear-gradient(to right, rgba(220,246,235,.98), rgba(220,236,255,.72) 65%, rgba(255,255,255,0));
    padding: .46em .58em;
    border-bottom: 2px solid var(--sage);
    border-top: 1px solid var(--mint-300);
  }

  .unidad > p:first-of-type{
    margin-top: .9em;
    padding: .55em .7em;
    background: var(--gray-050);
    border: 1px solid var(--gray-200);
    font-size: 9.45pt;
    color: var(--ink-soft);
  }

  .highlight {
    background: linear-gradient(to right, #dff7ec, #eef7ff 78%, #f9fcfb 100%);
    border-left: 5px solid var(--sage);
    padding: .72em .88em;
    margin: .95em 0;
    color: #315257;
    page-break-inside: avoid;
    break-inside: avoid;
  }

  .highlight strong{
    color: var(--title);
  }

  .table-title,
  .table-subtitle{
    font-size: 11.7pt;
    color: var(--title);
    margin: 1.15em 0 .55em;
    padding: .3em .55em;
    background: linear-gradient(to right, #ddf6ea, #eaf4ff 72%, transparent 96%);
    border-left: 4px solid var(--teal);
    border-bottom: 1px solid var(--gray-200);
  }

  /* =========================
     IMÁGENES – APUNTE A5
  ========================= */

  figure{
    margin: 0;
  }

  .img-box{
    margin: 1.1em 0 1.25em;
    text-align: center;
    page-break-inside: avoid;
    break-inside: avoid;
  }

  .img-apunte,
  .unidad img,
  .cover img{
    display: block;
    width: 95%;
    max-width: 100%;
    max-height: 220px;
    height: auto;
    margin: 0 auto;
    object-fit: contain;
    border: none;
    border-radius: 14px;
    background: linear-gradient(135deg, #f8fbff 0%, #f5fcf8 50%, #fffdf7 100%);
    padding: 10px;
    box-sizing: border-box;
    box-shadow: 0 6px 18px rgba(80, 110, 130, 0.08);
    page-break-inside: avoid;
    break-inside: avoid;
  }

  .img-apunte.sm,
  .unidad img.sm,
  .cover img.sm{
    width: 80%;
    max-height: 150px;
  }

  .img-apunte.md,
  .unidad img.md,
  .cover img.md{
    width: 95%;
    max-height: 220px;
  }

  .img-apunte.lg,
  .unidad img.lg,
  .cover img.lg{
    width: 100%;
    max-height: 260px;
  }

  .img-apunte.wide,
  .unidad img.wide,
  .cover img.wide{
    width: 100%;
    max-height: 180px;
  }

  .img-apunte.tall,
  .unidad img.tall,
  .cover img.tall{
    width: 95%;
    max-height: 280px;
  }

  .img-apunte.compact,
  .unidad img.compact,
  .cover img.compact{
    width: 90%;
    max-height: 200px;
  }

  .img-apunte.float-right,
  .img-apunte.float-left,
  .unidad img.float-right,
  .unidad img.float-left,
  .cover img.float-right,
  .cover img.float-left{
    width: 100%;
    max-height: 200px;
  }

  .img-apunte.bg-slot,
  .unidad img.bg-slot,
  .cover img.bg-slot{
    width: 100%;
    max-height: 240px;
  }

  .img-apunte.hero-slot,
  .unidad img.hero-slot,
  .cover img.hero-slot{
    width: 100%;
    max-height: 280px;
  }

  .img-apunte.clean,
  .unidad img.clean,
  .cover img.clean{
    background: transparent;
    padding: 0;
    box-shadow: none;
    border-radius: 0;
  }

  .img-apunte.soft,
  .unidad img.soft,
  .cover img.soft{
    background: linear-gradient(135deg, #f9fcff 0%, #f4fbf8 50%, #fffef7 100%);
    padding: 12px;
    border-radius: 16px;
    box-shadow: 0 8px 20px rgba(95, 125, 145, 0.08);
  }

  .img-apunte.glow,
  .unidad img.glow,
  .cover img.glow{
    background: radial-gradient(circle at top left, rgba(255,255,255,.95), rgba(241,248,255,.92) 50%, rgba(244,252,247,.95) 100%);
    padding: 12px;
    border-radius: 16px;
    box-shadow: 0 10px 24px rgba(110, 135, 150, 0.10);
  }

  .img-box figcaption{
    margin-top: 6px;
    font-size: 9.2pt;
    color: #6d7580;
    font-style: italic;
  }

  /* Placeholder limpio y estético */
  .image-placeholder {
    width: 95%;
    min-height: 160px;
    margin: 1em auto 1.1em;
    border: none;
    border-radius: 16px;
    background:
      linear-gradient(135deg, rgba(249,252,255,1) 0%, rgba(242,250,247,1) 48%, rgba(255,252,245,1) 100%);
    color: #7a8791;
    font-size: 9.15pt;
    line-height: 1.45;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.1em;
    page-break-inside: avoid;
    break-inside: avoid;
    box-shadow: inset 0 0 0 1px rgba(190,210,220,.28), 0 6px 18px rgba(100,120,140,.06);
  }

  .image-placeholder.small{
    width: 80%;
    min-height: 120px;
  }

  .image-placeholder.tall{
    width: 95%;
    min-height: 240px;
  }

  .image-placeholder.wide{
    width: 100%;
    min-height: 160px;
  }

  .image-placeholder.compact{
    width: 95%;
    min-height: 180px;
  }

  .image-placeholder.float-right,
  .image-placeholder.float-left{
    width: 100%;
    min-height: 180px;
  }

  .image-placeholder.bg-slot,
  .image-placeholder.hero-slot{
    width: 100%;
    min-height: 220px;
  }

  .image-placeholder::before{
    content:"";
    display:none;
  }

  img{
    page-break-inside: avoid;
    break-inside: avoid;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin: .8em 0 1em;
    page-break-inside: auto;
  }

  th, td {
    border: 1px solid var(--line);
    padding: 8px 9px;
    vertical-align: top;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  th {
    background: linear-gradient(180deg, #4aa7a0 0%, #2d8a86 100%);
    color: #fff;
    font-size: 9pt;
    font-weight: 700;
    text-align: left;
  }

  td {
    background: #fcfefe;
    color: var(--ink);
    font-size: 9.55pt;
  }

  tbody tr:nth-child(even) td{
    background: #f6fbfb;
  }

  .nanda-table-wrap,
  .simple-table-wrap,
  .need-table-wrap,
  .clinical-table-wrap,
  .cranial-table-wrap,
  .compare-table-wrap,
  .interp-table-wrap,
  .role-table-wrap,
  .ecg-table-wrap{
    margin: 1em 0 1.2em;
    page-break-inside: avoid;
    break-inside: avoid;
    overflow: visible;
  }

  .nanda-table th,
  .need-table th,
  .cranial-table th,
  .ecg-table th{
    background: linear-gradient(180deg, #53b39d 0%, #2f9a88 100%);
  }

  .simple-table th{
    background: linear-gradient(180deg, #5d94d3 0%, #447ab8 100%);
  }

  .clinical-table th,
  .compare-table th,
  .interp-table th,
  .role-table th{
    background: linear-gradient(180deg, #6ba8c8 0%, #4d88b0 100%);
    color:#fff;
  }

  .nanda-table td.col-main,
  .need-table td.left,
  .cranial-table td.left,
  .compare-table td.label,
  .role-table td.role,
  .ecg-table td.left,
  .interp-table td.score{
    background: linear-gradient(180deg, #dff7ec 0%, #d7f0f5 100%);
    color: var(--title);
    font-weight: 700;
  }

  .nanda-table td.col-code,
  .simple-table td.code{
    background: linear-gradient(180deg, #eef5ff 0%, #e0efff 100%);
    color: #315267;
    text-align: center;
    font-weight: 700;
  }

  .nanda-table td.col-result,
  .need-table td.right,
  .cranial-table td.right,
  .compare-table td.col,
  .role-table td.function,
  .ecg-table td.right,
  .interp-table td.result{
    background: #fbfeff;
    color: #334d54;
  }

  .simple-table td.label{
    background: linear-gradient(180deg, #eefaf3 0%, #f6fcff 100%);
    color: var(--title);
    font-weight: 700;
  }

  .simple-table td.function{
    color: #355b73;
  }

  .clinical-table td{
    background: #fcfeff;
  }

  .clinical-table tbody tr:nth-child(even) td,
  .compare-table tbody tr:nth-child(even) td.col,
  .interp-table tbody tr:nth-child(even) td.result,
  .role-table tbody tr:nth-child(even) td:not(.role),
  .ecg-table tbody tr:nth-child(even) td.right,
  .need-table tbody tr:nth-child(even) td.right,
  .cranial-table tbody tr:nth-child(even) td.right{
    background: #f4f9fa;
  }

  .page-footer{
    position: fixed;
    left: 0;
    right: 0;
    bottom: 6mm;
    font-size: 8.4pt;
    color: #6d8186;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 13mm;
    pointer-events: none;
  }

  .page-footer .page-num::before{
    content: "Página " counter(page);
  }

  @media print{
    body{
      counter-reset: page;
    }
    .page-footer{
      position: fixed;
    }
    .page-break{
      counter-increment: page;
    }
    .cover, .index, .unidad{
      page-break-inside: avoid;
    }
    h2, h3, h4, .highlight, .image-placeholder{
      page-break-after: avoid;
    }
    table, tr, td, th{
      page-break-inside: avoid;
    }
  }

  @media screen{
    body{
      max-width: 148mm;
      margin: 0 auto;
      padding: 10mm 13mm 18mm;
      background: #eef3f4;
    }
    .sheet-preview{
      background: #fff;
    }
  }

  .index li:nth-child(4n+1) span:last-child{ background:#dff7ec; border-color:#9ed9bf; color:#146c63; }
  .index li:nth-child(4n+2) span:last-child{ background:#e4f0ff; border-color:#b7d1f5; color:#2b6cb0; }
  .index li:nth-child(4n+3) span:last-child{ background:#eef3ff; border-color:#c6cff4; color:#5c6ac4; }
  .index li:nth-child(4n+4) span:last-child{ background:#eefbf6; border-color:#b6e7d1; color:#1f7d68; }

  .unidad > h2{ box-shadow: inset 0 0 0 1px rgba(69,163,132,.10); }
  .unidad:nth-of-type(4n+1) > h2{ border-left: 6px solid #45a384; }
  .unidad:nth-of-type(4n+2) > h2{ border-left: 6px solid #5da8d8; }
  .unidad:nth-of-type(4n+3) > h2{ border-left: 6px solid #7aa7d8; }
  .unidad:nth-of-type(4n+4) > h2{ border-left: 6px solid #6fc0a7; }

  .unidad h3:nth-of-type(3n+1){ border-left-color:#45a384; color:#146c63; }
  .unidad h3:nth-of-type(3n+2){ border-left-color:#5da8d8; color:#2b6cb0; }
  .unidad h3:nth-of-type(3n+3){ border-left-color:#7f9dd8; color:#5668b6; }

  .highlight{ border-radius: 4px; }
  .highlight:nth-of-type(odd){ border-left-color:#45a384; }
  .highlight:nth-of-type(even){ border-left-color:#5da8d8; }

  tbody tr:nth-child(even) td{ background: #f4fbfc; }
  .simple-table tbody tr:nth-child(even) td{ background:#eef5ff; }
  .need-table tbody tr:nth-child(even) td.right{ background:#eef9ff; }
  .clinical-table tbody tr:nth-child(even) td{ background:#eefaf6; }

  /* ===== Versión colorinchi / estilo apunte resaltado ===== */
  :root{
    --coral:#ff8f8f;
    --sun:#ffd86f;
    --lav:#cbb6ff;
    --pink:#ffb7df;
    --mint-bright:#8de0b8;
    --sky:#8ecbff;
    --peach:#ffc8a2;
    --lemon:#fff1a6;
    --lilac:#e5d7ff;
    --aqua:#b8f0ec;
  }

  body{
    background: #fffdfd;
  }

  p strong,
  li strong,
  td strong{
    color:#253b57;
    padding: 0 .12em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    background-image: linear-gradient(transparent 52%, rgba(255,241,166,.95) 52%);
  }

  em{
    font-style: normal;
    padding: 0 .1em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    background-image: linear-gradient(transparent 58%, rgba(229,215,255,.95) 58%);
    color:#5d4f83;
  }

  ul li::marker,
  ol li::marker{
    color:#38a169;
    font-weight:700;
  }

  .cover{
    border: 2px solid #c9b6ff;
    background:
      linear-gradient(180deg, #fff2f8 0%, #eef8ff 28%, #f1fff8 60%, #fffcea 100%);
  }

  .cover::before{ border-color: rgba(255,143,143,.35); }
  .cover::after{ border-color: rgba(142,203,255,.34); inset:13mm; }

  .cover h1{
    color:#7d4cc4;
    text-shadow:none;
  }

  .cover h2{
    color:#3d6985;
    background: linear-gradient(to right, rgba(255,216,111,.18), rgba(255,183,223,.18));
    padding:.25em .8em;
    border-radius:999px;
  }

  .index h2{
    background: linear-gradient(to right, rgba(255,183,223,.35), rgba(255,216,111,.32), rgba(184,240,236,.35), rgba(229,215,255,.38));
    border:1px solid #eadcf6;
    border-left:6px solid #7d4cc4;
  }

  .index ul{
    border: 1.5px solid #e4d9f4;
    background: linear-gradient(180deg, #fffefe 0%, #fcfcff 100%);
  }

  .index li:nth-child(6n+1){ background:#fff4f9; }
  .index li:nth-child(6n+2){ background:#f3fbff; }
  .index li:nth-child(6n+3){ background:#f5fff8; }
  .index li:nth-child(6n+4){ background:#fffdf0; }
  .index li:nth-child(6n+5){ background:#f7f3ff; }
  .index li:nth-child(6n+6){ background:#fff7f1; }

  .index li span:first-child{
    position:relative;
    padding-left:.25em;
  }

  .index li span:first-child::before{
    content:"";
    display:inline-block;
    width:.55em;
    height:.55em;
    border-radius:50%;
    margin-right:.45em;
    vertical-align:middle;
    background:#8de0b8;
  }
  .index li:nth-child(6n+2) span:first-child::before{ background:#8ecbff; }
  .index li:nth-child(6n+3) span:first-child::before{ background:#ffb7df; }
  .index li:nth-child(6n+4) span:first-child::before{ background:#ffd86f; }
  .index li:nth-child(6n+5) span:first-child::before{ background:#cbb6ff; }
  .index li:nth-child(6n+6) span:first-child::before{ background:#ffc8a2; }

  .index li:nth-child(6n+1) span:last-child{ background:#dcfff0; border-color:#9ee0bf; color:#197557; }
  .index li:nth-child(6n+2) span:last-child{ background:#e3f2ff; border-color:#b4d6ff; color:#29639b; }
  .index li:nth-child(6n+3) span:last-child{ background:#ffe7f4; border-color:#f5b4d7; color:#a04d7d; }
  .index li:nth-child(6n+4) span:last-child{ background:#fff4b9; border-color:#ead36f; color:#8a6a00; }
  .index li:nth-child(6n+5) span:last-child{ background:#efe7ff; border-color:#ccb7f5; color:#6a56b8; }
  .index li:nth-child(6n+6) span:last-child{ background:#ffe9da; border-color:#f4b995; color:#9a5d35; }

  .unidad{
    position:relative;
  }

  .unidad::before{
    content:"";
    position:absolute;
    left:-7mm;
    top:1.2em;
    width:3mm;
    height:28mm;
    border-radius:2mm;
    background: linear-gradient(180deg, #8de0b8, #8ecbff, #ffb7df, #ffd86f);
  }

  .unidad > h2{
    padding:.58em .7em;
    border-bottom-width:3px;
    border-radius: 8px 8px 0 0;
